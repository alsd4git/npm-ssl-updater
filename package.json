{
  "name": "npm-ssl-updater",
  "version": "1.0.0",
  "description": "CLI to harden Nginx Proxy Manager proxy hosts with Force SSL, HTTP/2, HSTS, and related options",
  "main": "update_ssl.js",
  "bin": {
    "npm-ssl-updater": "./bin/update.js"
  },
  "files": [
    "bin/",
    "update_ssl.js",
    "README.en.md",
    "README.it.md",
    "LICENSE",
    ".env.example"
  ],
  "scripts": {
    "start": "node update_ssl.js",
    "test": "node --test"
  },
  "keywords": [
    "nginx-proxy-manager",
    "ssl",
    "cli",
    "automation",
    "hsts",
    "http2",
    "reverse-proxy"
  ],
  "author": "Alessandro Digilio",
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "commander": "^11.0.0",
    "dotenv": "^17.3.1"
  }
}
